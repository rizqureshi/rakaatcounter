<section class="main-404 section-padding" aria-label="Page not found">
  <div class="container">
    <div class="main-404__inner">

      <div class="main-404__decoration" aria-hidden="true">
        {%- render 'icon-geometric-pattern' -%}
      </div>

      <p class="main-404__code">404</p>
      <h1 class="main-404__heading">{{ section.settings.heading }}</h1>
      <p class="main-404__text">{{ section.settings.text }}</p>

      <div class="main-404__actions">
        <a href="{{ routes.root_url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">Shop All</a>
      </div>

      {%- if section.settings.show_search -%}
        <div class="main-404__search">
          <p class="main-404__search-label">Or search for something:</p>
          <form action="{{ routes.search_url }}" method="get" role="search" class="main-404__search-form">
            <input
              type="search"
              name="q"
              class="main-404__search-input"
              placeholder="Search our store..."
              aria-label="Search our store"
            >
            <button type="submit" class="btn btn--primary main-404__search-btn" aria-label="Submit search">
              {%- render 'icon-search' -%}
            </button>
          </form>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Not Found"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Body text",
      "default": "The page you were looking for doesn't exist. It may have been moved or removed."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Back to Home"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search form",
      "default": true
    }
  ]
}
{% endschema %}
