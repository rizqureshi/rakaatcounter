<header class="header{% if settings.sticky_header %} header--sticky{% endif %}" role="banner">
  <div class="header__inner container">

    {%- comment -%} Mobile menu toggle {%- endcomment -%}
    <button class="header__menu-toggle" aria-controls="mobile-nav" aria-expanded="false" aria-label="{{ 'accessibility.menu' | t }}">
      <span class="header__menu-icon"></span>
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio | round -%}
          {{
            settings.logo
            | image_url: width: settings.logo_width
            | image_tag:
              class: 'header__logo-image',
              alt: shop.name,
              width: settings.logo_width,
              height: logo_height
          }}
        {%- else -%}
          <span class="header__brand-lockup">
            <span class="header__brand-mark" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="7" y="10" width="6" height="8" fill="#FAF7F2"/>
                <path d="M7 10 C7 4 13 4 13 10Z" fill="#FAF7F2"/>
                <line x1="3" y1="18" x2="17" y2="18" stroke="rgba(201,168,76,0.85)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="header__brand-copy">
              <span class="header__logo-text">{{ shop.name }}</span>
              <span class="header__logo-tagline">Focused Salah Companion</span>
            </span>
          </span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Desktop navigation {%- endcomment -%}
    <nav class="header__nav" role="navigation" aria-label="{{ 'accessibility.main_menu' | t }}">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links != blank -%}
          <div class="header__nav-item header__nav-item--dropdown">
            <button class="header__nav-link header__nav-link--dropdown-toggle" aria-expanded="false">
              {{ link.title }}
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
            <ul class="header__dropdown" role="list">
              {%- for child_link in link.links -%}
                <li>
                  <a href="{{ child_link.url }}" class="header__dropdown-link{% if child_link.active %} active{% endif %}">
                    {{ child_link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="header__nav-link{% if link.active %} active{% endif %}">
            {{ link.title }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    {%- comment -%} Header actions {%- endcomment -%}
    <div class="header__actions">
      <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="{{ 'accessibility.account' | t }}" data-tooltip="Account">
        {%- render 'icon-account' -%}
      </a>

      <button
        class="header__icon-btn header__cart-btn"
        aria-label="{{ 'accessibility.cart' | t }} ({{ cart.item_count }})"
        aria-controls="cart-drawer"
        aria-expanded="false"
        data-tooltip="Shopping Basket"
      >
        {%- render 'icon-cart' -%}
        <span class="header__cart-count" aria-hidden="true" style="{% unless cart.item_count > 0 %}display:none{% endunless %}">{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  {%- comment -%} Mobile navigation {%- endcomment -%}
  <nav id="mobile-nav" class="mobile-nav" aria-label="{{ 'accessibility.main_menu' | t }}" aria-hidden="true">
    <ul class="mobile-nav__list" role="list">
      {%- for link in linklists[section.settings.menu].links -%}
        <li class="mobile-nav__item">
          <a href="{{ link.url }}" class="mobile-nav__link{% if link.active %} active{% endif %}">
            {{ link.title }}
          </a>
          {%- if link.links != blank -%}
            <ul class="mobile-nav__sub" role="list">
              {%- for child_link in link.links -%}
                <li>
                  <a href="{{ child_link.url }}" class="mobile-nav__sub-link">{{ child_link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
