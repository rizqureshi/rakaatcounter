<section class="hero{% if section.settings.full_height %} hero--full{% endif %}" aria-label="{{ section.settings.heading }}">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {%- assign hero_img_alt = section.settings.image.alt | escape -%}
      {%- assign hero_img_width = section.settings.image.width -%}
      {%- assign hero_img_height = section.settings.image.height -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          class: 'hero__image',
          loading: 'eager',
          fetchpriority: 'high',
          alt: hero_img_alt,
          widths: '750, 1100, 1500, 1920',
          sizes: '100vw',
          width: hero_img_width,
          height: hero_img_height
      }}
    {%- else -%}
      <img
        src="{{ 'hero-bg.jpg' | asset_url }}"
        class="hero__image"
        loading="eager"
        fetchpriority="high"
        alt="A serene Islamic prayer room with warm light and geometric patterns"
        width="1536"
        height="1024"
      >
    {%- endif -%}
    <div class="hero__overlay" style="--hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__content-inner">
      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary hero__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "presets": [
    {
      "name": "Hero banner"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handcrafted for every prayer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Count Every Rakaat with Intention"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "A beautifully crafted prayer counter designed to help you stay present and mindful in every moment of worship."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
