<section class="image-with-text section-padding">
  <div class="container">
    <div class="image-with-text__grid image-with-text__grid--{{ section.settings.image_position }}">

      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          {%- assign iwt_img_alt = section.settings.image.alt | escape -%}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              class: 'image-with-text__image',
              loading: 'lazy',
              alt: iwt_img_alt
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'image-with-text__placeholder' }}
        {%- endif -%}
      </div>

      <div class="image-with-text__content">
        {%- if section.settings.subheading != blank -%}
          <p class="image-with-text__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="image-with-text__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-with-text__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'feature' -%}
              <div class="image-with-text__feature" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="image-with-text__feature-icon">{{ block.settings.icon }}</span>
                {%- endif -%}
                <div>
                  <strong>{{ block.settings.heading }}</strong>
                  <p>{{ block.settings.text }}</p>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "presets": [
    {
      "name": "Image with text"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Feature heading"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
