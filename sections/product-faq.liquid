<section class="product-faq section-padding" aria-labelledby="product-faq-heading">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h2 class="product-faq__heading" id="product-faq-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="product-faq__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="product-faq__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' and block.settings.question != blank -%}
            <details class="product-faq__item" {{ block.shopify_attributes }}>
              <summary class="product-faq__question">
                {{ block.settings.question }}
                <svg class="product-faq__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              {%- if block.settings.answer != blank -%}
                <div class="product-faq__answer rte">{{ block.settings.answer }}</div>
              {%- endif -%}
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ]
}
{% endschema %}
