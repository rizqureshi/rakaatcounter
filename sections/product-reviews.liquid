<section class="product-reviews section-padding" aria-label="Customer reviews">
  <div class="container">

    <div class="product-reviews__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="product-reviews__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="product-reviews__app-blocks">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-reviews__placeholder">
        <span class="product-reviews__placeholder-icon" aria-hidden="true">✦</span>
        <p class="product-reviews__placeholder-text">{{ section.settings.placeholder_text }}</p>
        {%- if section.settings.feedback_link != blank -%}
          <a href="{{ section.settings.feedback_link }}" class="product-reviews__feedback-btn">
            {{ section.settings.feedback_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Customer reviews",
  "tag": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder text (shown when no review app is connected)",
      "default": "Customer reviews will appear here once a review app is connected."
    },
    {
      "type": "url",
      "id": "feedback_link",
      "label": "Feedback link (e.g. your contact page)"
    },
    {
      "type": "text",
      "id": "feedback_label",
      "label": "Feedback button label",
      "default": "Send us your feedback"
    }
  ]
}
{% endschema %}
