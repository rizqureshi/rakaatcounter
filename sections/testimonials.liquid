<section class="testimonials section-padding">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading text-center">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="section-subheading text-center">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="star{% if i > block.settings.rating %} star--empty{% endif %}" aria-hidden="true">★</span>
            {%- endfor -%}
          </div>
          <blockquote class="testimonial-card__quote">
            <p>{{ block.settings.quote }}</p>
          </blockquote>
          <footer class="testimonial-card__author">
            {%- if block.settings.author_image != blank -%}
              {{
                block.settings.author_image
                | image_url: width: 56, height: 56, crop: 'center'
                | image_tag:
                  class: 'testimonial-card__author-image',
                  loading: 'lazy',
                  alt: block.settings.author_name
              }}
            {%- endif -%}
            <div>
              <cite class="testimonial-card__author-name">{{ block.settings.author_name }}</cite>
              {%- if block.settings.author_location != blank -%}
                <span class="testimonial-card__author-location">{{ block.settings.author_location }}</span>
              {%- endif -%}
            </div>
          </footer>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "presets": [
    {
      "name": "Testimonials"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This rakaat counter has transformed my prayer experience. The quality is exceptional and it keeps me focused throughout salah."
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Ibrahim A."
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author location",
          "default": "London, UK"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Loved by the Community"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Trusted by thousands of Muslims around the world"
    }
  ]
}
{% endschema %}
