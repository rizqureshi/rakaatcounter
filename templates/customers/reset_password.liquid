<div class="customer-page section-padding">
  <div class="container container--narrow">

    <h1 class="customer-page__title">Reset Password</h1>
    <p class="customer-page__subtitle">Enter your email and we'll send you a reset link.</p>

    {%- form 'recover_customer_password', class: 'customer-form' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-success" role="status">
          We've sent you an email with a link to reset your password.
        </div>
      {%- else -%}
        {%- if form.errors -%}
          <div class="form-error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-group">
          <label class="form-label" for="RecoverEmail">Email address</label>
          <input
            type="email"
            id="RecoverEmail"
            name="email"
            class="form-input"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            autofocus
          >
        </div>

        <button type="submit" class="btn btn--primary btn--full">Send Reset Link</button>
      {%- endif -%}
    {%- endform -%}

    <div class="customer-page__links">
      <a href="{{ routes.account_login_url }}" class="customer-page__link">← Back to sign in</a>
    </div>

  </div>
</div>
