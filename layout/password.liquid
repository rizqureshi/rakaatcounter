<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <title>{{ shop.name }} &mdash; {{ 'general.password_page.opening_soon' | t }}</title>

    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">
  </head>

  <body class="template-password">
    <div class="password-page">
      <header class="password-header">
        <h1 class="password-logo">{{ shop.name }}</h1>
      </header>

      <main class="password-main">
        {{ content_for_layout }}
      </main>

      <footer class="password-footer">
        <p>{{ powered_by_link }}</p>
      </footer>
    </div>

    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
