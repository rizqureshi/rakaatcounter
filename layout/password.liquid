<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} &mdash; Launching Soon</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body.template-password {
        min-height: 100vh;
        background-color: #FAF7F2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'DM Sans', sans-serif;
        color: #2C1A0E;
        text-align: center;
        padding: 2rem;
      }

      .password-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        max-width: 560px;
        width: 100%;
      }

      .password-logo-wrap img {
        max-height: 100px;
        width: auto;
      }

      .password-logo-text {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2rem;
        color: #2D5016;
        letter-spacing: 0.02em;
      }

      .password-divider {
        width: 48px;
        height: 2px;
        background: #C9A84C;
        border-radius: 2px;
      }

      .password-heading {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2rem, 5vw, 3rem);
        color: #2D5016;
        line-height: 1.2;
        font-weight: 600;
      }

      .password-subtext {
        font-size: 1rem;
        color: #6B5744;
        line-height: 1.7;
        max-width: 420px;
      }

      .password-notify {
        width: 100%;
      }

      .password-notify-heading {
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6B5744;
        margin-bottom: 0.75rem;
      }

      .password-form {
        display: flex;
        gap: 0.5rem;
        width: 100%;
      }

      .password-form input[type="email"] {
        flex: 1;
        padding: 0.65rem 1rem;
        border: 1px solid #E8DDD0;
        border-radius: 999px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9375rem;
        background: #fff;
        color: #2C1A0E;
        outline: none;
      }

      .password-form input[type="email"]:focus {
        border-color: #C9A84C;
      }

      .password-form button {
        padding: 0.65rem 1.4rem;
        background: #2D5016;
        color: #FAF7F2;
        border: none;
        border-radius: 999px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
      }

      .password-form button:hover {
        background: #3a6a1e;
      }

      .password-success {
        font-size: 0.9375rem;
        color: #2D5016;
        font-weight: 600;
      }

      .password-footer-note {
        font-size: 0.8125rem;
        color: #6B5744;
        opacity: 0.7;
      }

      .password-login-link {
        font-size: 0.8125rem;
        color: #6B5744;
      }

      .password-login-link a {
        color: #C9A84C;
        text-decoration: none;
        font-weight: 600;
      }

      @media (max-width: 480px) {
        .password-form {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body class="template-password">
    <div class="password-page">

      <div class="password-logo-wrap">
        {%- if settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: 200
            | image_tag: alt: shop.name, width: 200, loading: 'eager'
          }}
        {%- else -%}
          <span class="password-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </div>

      <div class="password-divider"></div>

      <h1 class="password-heading">Launching Soon</h1>

      <p class="password-subtext">
        The Rakaat Counter is almost ready. We're putting the finishing touches on our store and will be open for orders very soon. Leave your email and we'll notify you the moment we go live.
      </p>

      <div class="password-notify">
        <p class="password-notify-heading">Notify me when we launch</p>
        {%- form 'customer', class: 'password-form' -%}
          <input type="hidden" name="contact[tags]" value="prospect">
          {%- if form.posted_successfully? -%}
            <p class="password-success">You're on the list — we'll be in touch!</p>
          {%- else -%}
            <input
              type="email"
              name="contact[email]"
              placeholder="Your email address"
              required
              aria-label="Email address"
            >
            <button type="submit">Notify me</button>
          {%- endif -%}
        {%- endform -%}
      </div>

      <p class="password-footer-note">Sensor-based rakaat tracking &mdash; no phone required</p>

      <p class="password-login-link">
        {{ 'general.password_page.login_form_heading' | t }}
        {{ content_for_layout }}
      </p>

    </div>
  </body>
</html>
